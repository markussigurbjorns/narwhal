digraph narwhal_publish_flow {
    graph [
        rankdir=LR,
        splines=true,
        nodesep=0.5,
        ranksep=0.9,
        pad=0.2,
        fontname="Helvetica",
        fontsize=12,
        labelloc="t",
        label="Narwhal Publish Flow"
    ];

    node [
        shape=box,
        style="rounded,filled",
        fontname="Helvetica",
        fontsize=11,
        color="#314158",
        fillcolor="#f7f4ec",
        margin="0.14,0.08"
    ];

    edge [
        color="#52627a",
        fontname="Helvetica",
        fontsize=10,
        arrowsize=0.8
    ];

    browser [
        label="Browser Publisher\nclients/app.js\ncreateOffer + local media",
        fillcolor="#fdf1d4"
    ];

    route_post [
        label="POST /whip/:room\nserver::whip_post()",
        fillcolor="#eaf4f8"
    ];

    room_manager [
        label="RoomManager::whip_publish()",
        fillcolor="#eef8ec"
    ];

    peer [
        label="PeerSession\nWhipPublisher",
        fillcolor="#f9edf1"
    ];

    gst [
        label="GstRuntime\nGLib thread executor",
        fillcolor="#f9edf1"
    ];

    negotiate [
        label="start()\nthen\nnegotiate_as_answerer()",
        fillcolor="#f9edf1"
    ];

    tap [
        label="install_rtp_tap()",
        fillcolor="#f9edf1"
    ];

    play [
        label="play()",
        fillcolor="#f9edf1"
    ];

    router [
        label="BroadcastRouter\nroom router",
        fillcolor="#eef8ec"
    ];

    fanout_task [
        label="spawn fanout task\nwhile let Some(pkt)\nrouter.fanout(pkt)",
        fillcolor="#eef8ec"
    ];

    ice [
        label="IceQueue +\nstart_ice_collector()",
        fillcolor="#eef8ec"
    ];

    session_store [
        label="store PublisherSession\nin room state",
        fillcolor="#eef8ec"
    ];

    response [
        label="201 Created\nanswer SDP + Location",
        fillcolor="#eaf4f8"
    ];

    patch_route [
        label="PATCH /whip/:room/:pub\nserver::whip_patch()",
        fillcolor="#eaf4f8"
    ];

    get_ice_route [
        label="GET /whip/:room/:pub/ice\nserver::whip_get_ice()",
        fillcolor="#eaf4f8"
    ];

    add_ice [
        label="PeerSession::add_ice_candidate()",
        fillcolor="#f9edf1"
    ];

    drain_ice [
        label="IceQueue::drain()",
        fillcolor="#eef8ec"
    ];

    browser -> route_post [label="SDP offer"];
    route_post -> room_manager [label="whip_publish(room, offer)"];
    room_manager -> peer [label="PeerSession::new()"];
    gst -> peer [label="runtime backing"];
    peer -> negotiate [label="prepare answer"];
    negotiate -> tap [label="publisher receives RTP"];
    tap -> play [label="tap ready"];
    play -> router [label="get/create room router"];
    router -> fanout_task [label="use room router clone"];
    tap -> fanout_task [label="rx.recv() packets"];
    room_manager -> ice [label="subscribe to local ICE"];
    room_manager -> session_store [label="publisher id + peer + ice"];
    session_store -> response [label="SdpResponse"];
    response -> browser [label="answer SDP + resource URL"];

    browser -> patch_route [label="local ICE candidate"];
    patch_route -> room_manager [label="whip_trickle(...)"];
    room_manager -> add_ice [label="lookup publisher peer"];
    add_ice -> peer [label="apply remote ICE"];

    browser -> get_ice_route [label="poll server ICE"];
    get_ice_route -> room_manager [label="whip_drain_ice(...)"];
    room_manager -> drain_ice [label="lookup publisher queue"];
    drain_ice -> browser [label="ICE candidate list"];
}
